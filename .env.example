# =====================================================
# COCO CLAW 后端环境变量配置
# 复制此文件为 .env 后修改对应值
# =====================================================

# 数据库配置
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/coco_claw
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root

# Redis 配置
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=

# Nacos 注册中心
NACOS_DISCOVERY_SERVER_ADDR=124.243.191.159:8848

# 支付宝配置
ALIPAY_APP_ID=2021000000000000
ALIPAY_PRIVATE_KEY=支付宝私钥
ALIPAY_PUBLIC_KEY=支付宝公钥
ALIPAY_NOTIFY_URL=https://your-domain.com/api/payment/callback/alipay

# 微信支付配置
WECHATPAY_MCHID=商户号
WECHATPAY_SERIAL_NO=证书序列号
WECHATPAY_API_KEY=API密钥
WECHATPAY_APPID=AppID
WECHATPAY_NOTIFY_URL=https://your-domain.com/api/payment/callback/wechat

# 上游 APIKEY 服务商配置 (可选)
UPSTREAM_API_KEY=上游API密钥
UPSTREAM_API_URL=https://api.upstream.com
