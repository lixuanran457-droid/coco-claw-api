<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cococlown.cococlawservice.mapper.CategoryMapper">

    <resultMap id="BaseResultMap" type="com.cococlown.cococlawservice.entity.Category">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="icon" property="icon"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <!-- 查询所有启用的分类 -->
    <select id="selectEnabledCategories" resultMap="BaseResultMap">
        SELECT * FROM category
        WHERE status = 1
        ORDER BY sort_order ASC
    </select>

</mapper>
